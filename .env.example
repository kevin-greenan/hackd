DATABASE_URL="postgresql://hackd:hackd_dev_password@db:5432/hackd?schema=public"
APP_URL="http://localhost:3000"
SESSION_SECRET="replace-with-at-least-32-random-characters"
SEED_ADMIN_EMAIL="admin@hackd.local"
SEED_ADMIN_PASSWORD="change-me-in-development"
SEED_LEARNER_EMAIL="learner@hackd.local"
SEED_LEARNER_PASSWORD="change-me-in-development"
FILE_STORAGE_DIR="/app/data/uploads"
MAX_ATTACHMENT_BYTES="5242880"
CHALLENGE_SUBMISSION_LIMIT="10"
CHALLENGE_SUBMISSION_WINDOW_SECONDS="60"
RUNTIME_RUNNER_URL="http://runner:4010"
RUNTIME_ALLOWED_IMAGES="nginx:alpine"
CHALLENGE_PUBLIC_HOST="http://localhost"
HACKD_BRAND_NAME="hackd"
HACKD_BRAND_TAGLINE="Containerized control plane for hands-on security training."
HACKD_BRAND_LOGO_URL=""
HACKD_BRAND_ADMIN_LABEL="Admin control plane"
HACKD_BRAND_LEARNER_LABEL="Learner workspace"
HACKD_THEME_PRIMARY="#14a391"
HACKD_THEME_PRIMARY_FOREGROUND="#f8ffff"
HACKD_THEME_BACKGROUND="#f8fafc"
HACKD_THEME_SURFACE="#eef5f8"
HACKD_THEME_FOREGROUND="#0f172a"
HACKD_THEME_CARD="#ffffff"
HACKD_THEME_MUTED="#e2e8f0"
HACKD_THEME_MUTED_FOREGROUND="#536171"
HACKD_THEME_BORDER="#cbd5e1"
